const router = require('express').Router();
const PropertyController = require('../controllers/property_controller');
const auth = require('../middlewares/auth');
const role = require('../middlewares/role');
const upload = require('../middlewares/upload');
const pool = require('../config/db');

// ─── SPECIFIC NAMED ROUTES FIRST ─────────────────────────
router.get('/my-listings', auth, role(['property_manager', 'admin']), PropertyController.myListings);
router.get('/stats', auth, role(['property_manager']), PropertyController.getManagerStats);

// ─── NEARBY ──────────────────────────────────────────────
router.get('/nearby', async (req, res) => {
    try {
        const { lat, lng, radius_km = 10 } = req.query;
        if (!lat || !lng) {
            return res.status(400).json({ status: false, message: 'lat and lng are required' });
        }
        const result = await pool.query(`
            SELECT p.*,
                u.full_name AS owner_name, u.phone AS owner_phone, u.avatar AS owner_avatar,
                COALESCE(JSON_AGG(DISTINCT pi.image_url) FILTER (WHERE pi.image_url IS NOT NULL), '[]') AS images,
                MIN(pv.video_url) AS video_path,
                COALESCE(JSON_AGG(DISTINCT pa.amenity) FILTER (WHERE pa.amenity IS NOT NULL), '[]') AS amenities,
                (6371 * acos(LEAST(1.0, GREATEST(-1.0,
                    cos(radians($1::float)) * cos(radians(p.latitude::float)) *
                    cos(radians(p.longitude::float) - radians($2::float)) +
                    sin(radians($1::float)) * sin(radians(p.latitude::float))
                )))) AS distance_km
            FROM properties p
            JOIN users u ON u.id = p.user_id
            LEFT JOIN property_images pi ON pi.property_id = p.id
            LEFT JOIN property_videos pv ON pv.property_id = p.id
            LEFT JOIN property_amenities pa ON pa.property_id = p.id
            WHERE p.status IN ('active', 'pending') AND u.is_suspended = false
            AND p.latitude IS NOT NULL AND p.longitude IS NOT NULL
            GROUP BY p.id, u.full_name, u.phone, u.avatar
            HAVING (6371 * acos(LEAST(1.0, GREATEST(-1.0,
                cos(radians($1::float)) * cos(radians(p.latitude::float)) *
                cos(radians(p.longitude::float) - radians($2::float)) +
                sin(radians($1::float)) * sin(radians(p.latitude::float))
            )))) <= $3
            ORDER BY distance_km ASC
        `, [parseFloat(lat), parseFloat(lng), parseFloat(radius_km)]);
        res.json({ status: true, properties: result.rows });
    } catch (error) {
        console.error('❌ Nearby error:', error.message);
        res.status(500).json({ status: false, message: error.message });
    }
});

// ─── LIST ALL (with filters) ──────────────────────────────
router.get('/', async (req, res) => {
    try {
        const {
            property_type, listing_type, min_price,
            max_price, bedrooms, purpose, user_id
        } = req.query;

        let conditions = [`p.status IN ('active', 'pending')`, `u.is_suspended = false`];
        let values = [];
        let idx = 1;

        if (property_type) {
            conditions.push(`p.property_type = $${idx++}`);
            values.push(property_type);
        }
        if (listing_type) {
            conditions.push(`p.listing_type = $${idx++}`);
            values.push(listing_type);
        }
        if (min_price) {
            conditions.push(`p.rent_price >= $${idx++}`);
            values.push(parseFloat(min_price));
        }
        if (max_price) {
            conditions.push(`p.rent_price <= $${idx++}`);
            values.push(parseFloat(max_price));
        }
        if (bedrooms) {
            conditions.push(`p.bedrooms >= $${idx++}`);
            values.push(parseInt(bedrooms));
        }
        if (purpose) {
            conditions.push(`p.purpose = $${idx++}`);
            values.push(purpose);
        }
        if (user_id) {
            conditions.push(`p.user_id = $${idx++}`);
            values.push(parseInt(user_id));
        }

        const result = await pool.query(`
            SELECT p.*, p.admin_approved, u.full_name AS owner_name, u.phone AS owner_phone, u.avatar AS owner_avatar,
                COALESCE(JSON_AGG(DISTINCT pi.image_url) FILTER (WHERE pi.image_url IS NOT NULL), '[]') AS images,
                MIN(pv.video_url) AS video_path,
                COALESCE(JSON_AGG(DISTINCT pa.amenity) FILTER (WHERE pa.amenity IS NOT NULL), '[]') AS amenities
            FROM properties p
            JOIN users u ON u.id = p.user_id
            LEFT JOIN property_images pi ON pi.property_id = p.id
            LEFT JOIN property_videos pv ON pv.property_id = p.id
            LEFT JOIN property_amenities pa ON pa.property_id = p.id
            WHERE ${conditions.join(' AND ')}
            GROUP BY p.id, u.full_name, u.phone, u.avatar
            ORDER BY p.created_at DESC
        `, values);

        res.json({ status: true, properties: result.rows });
    } catch (error) {
        console.error('❌ Properties list error:', error.message);
        res.status(500).json({ status: false, message: error.message });
    }
});

