router.get('/:id/stats', auth, async (req, res) => {
    try {
        const propertyId = parseInt(req.params.id);

        const [viewsRes, bookingsRes, revenueRes, recentViewsRes] = await Promise.all([
            pool.query('SELECT view_count FROM properties WHERE id = $1', [propertyId]),
            pool.query(`
                SELECT 
                    COUNT(*) as total,
                    COUNT(*) FILTER (WHERE status = 'visit_confirmed') as confirmed,
                    COUNT(*) FILTER (WHERE status = 'awaiting_visit') as pending,
                    COUNT(*) FILTER (WHERE status IN ('refund_approved','refunded')) as refunded
                FROM property_bookings WHERE property_id = $1
            `, [propertyId]),
            pool.query(`
                SELECT 
                    COALESCE(SUM(manager_amount), 0) as total_earned,
                    COALESCE(SUM(manager_amount) FILTER (WHERE escrow_status = 'released'), 0) as released,
                    COALESCE(SUM(manager_amount) FILTER (WHERE escrow_status = 'held'), 0) as held
                FROM property_bookings 
                WHERE property_id = $1 AND status NOT IN ('refund_approved','refunded','cancelled')
            `, [propertyId]),
            pool.query(`
                SELECT DATE(viewed_at) as date, COUNT(*) as views
                FROM property_views
                WHERE property_id = $1
                AND viewed_at > NOW() - INTERVAL '30 days'
                GROUP BY DATE(viewed_at)
                ORDER BY date DESC
            `, [propertyId]),
        ]);

        res.json({
            status: true,
            stats: {
                total_views: viewsRes.rows[0]?.view_count || 0,
                bookings: bookingsRes.rows[0],
                revenue: revenueRes.rows[0],
                recent_views: recentViewsRes.rows,
            }
        });
    } catch (e) {
        res.status(500).json({ status: false, message: e.message });
    }
});


